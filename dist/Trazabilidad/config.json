{
  "app": {
    "title": "Sistema de trazabilidad con doble scanner y PLC",
    "auto_start": true,
    "simulation_enabled": false
  },
  "scanners": {
    "right": {
      "name": "Nido derecho",
      "ip": "192.168.0.10",
      "port": 5000,
      "timeout_seconds": 0.4,
      "reconnect_interval_seconds": 0.5,
      "tcp_keepalive_enabled": true,
      "tcp_keepalive_idle_ms": 1000,
      "tcp_keepalive_interval_ms": 500,
      "tcp_keepalive_count": 2,
      "active_probe_enabled": false,
      "active_probe_interval_seconds": 1.0,
      "active_probe_timeout_seconds": 0.25,
      "active_probe_failures_before_disconnect": 2
    },
    "left": {
      "name": "Nido izquierdo",
      "ip": "192.168.0.11",
      "port": 5000,
      "timeout_seconds": 0.4,
      "reconnect_interval_seconds": 0.5,
      "tcp_keepalive_enabled": true,
      "tcp_keepalive_idle_ms": 1000,
      "tcp_keepalive_interval_ms": 500,
      "tcp_keepalive_count": 2,
      "active_probe_enabled": false,
      "active_probe_interval_seconds": 1.0,
      "active_probe_timeout_seconds": 0.25,
      "active_probe_failures_before_disconnect": 2
    }
  },
  "plc": {
    "port": "COM3",
    "baudrate": 9600,
    "bytesize": 7,
    "parity": "E",
    "stopbits": 1,
    "timeout": 1.0,
    "d0_values": {
      "reset": "0000",
      "ok": "0100",
      "error": "0200"
    },
    "reset_delay_ms": 500,
    "write_timeout": 1.0,
    "require_port_presence": true
  },
  "validation": {
    "expected_length": 22,
    "scanner_error_tokens": [
      "ERROR",
      "NG",
      "NOREAD",
      "NO READ",
      "NO_READ"
    ]
  },
  "cycle": {
    "read_timeout_ms": 3000,
    "cooldown_ms": 1000,
    "accept_first_useful_reading_only": true,
    "clear_buffers_after_cycle": true,
    "read_poll_interval_ms": 50,
    "plc_signal_hold_ms": 2000,
    "pair_timeout_ms": 3000,
    "incomplete_packet_idle_ms": 150
  },
  "simulation": {
    "cycle_interval_ms": 3500
  },
  "storage": {
    "excel_path": "data/base_datos_produccion.xlsx",
    "sqlite_path": "data/trazabilidad.db",
    "include_error_rows_in_duplicates": false
  },
  "logging": {
    "level": "INFO",
    "file_path": "logs/trazabilidad.log",
    "max_bytes": 1048576,
    "backup_count": 5
  },
  "connection_monitor": {
    "health_check_interval_seconds": 0.3,
    "scanner_health_check_interval_seconds": 0.3,
    "reconnect_interval_seconds": 2.0,
    "fast_reconnect_window_seconds": 12.0,
    "fast_reconnect_interval_seconds": 0.5,
    "slow_reconnect_interval_seconds": 2.0
  }
}